# Copy to .env and fill in your credentials.
# Get these from https://console.cloud.google.com/apis/credentials and
# https://programmablesearchengine.google.com/

GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Daily quota cap (Free tier = 100/day). The server refuses calls past this.
GOOGLE_CSE_DAILY_QUOTA=100

# Cache database location (relative to working directory).
MCP_CACHE_DB_PATH=.cache/cse.db

# HTTP timeout for CSE calls.
MCP_REQUEST_TIMEOUT_SEC=15.0
